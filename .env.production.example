# Streamly Production Environment Template
# Copy values manually on the production server. Do not commit real secrets.

# Runtime
NODE_ENV=production
PORT=8000
TRUST_PROXY=1

# Public URLs
APP_PUBLIC_BASE_URL=https://streamly.zytheran.me
SERVER_PUBLIC_BASE_URL=https://streamly.zytheran.me
API_DOCS_SERVER_URL=https://streamly.zytheran.me

# PostgreSQL / AWS RDS
DATABASE_URL=postgresql://USER:PASSWORD@RDS_HOST:5432/streamly?schema=public

# Redis / Upstash
REDIS_ENABLED=true
REDIS_URL=rediss://default:UPSTASH_PASSWORD@UPSTASH_HOST:6379

# JWT/Auth
ACCESS_TOKEN_SECRET=replace-with-strong-access-token-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=replace-with-strong-refresh-token-secret
REFRESH_TOKEN_EXPIRY=7d
EMAIL_VERIFICATION_TOKEN_EXPIRY=1d

# MFA / Authenticator app
MFA_ENABLED=true
MFA_ISSUER=Streamly
MFA_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-key
MFA_TRUST_TOKEN_EXPIRY_SECONDS=1800
MFA_CHALLENGE_EXPIRY_SECONDS=300
MFA_DEVICE_COOKIE_NAME=streamly_device_id
MFA_TRUST_COOKIE_NAME=streamly_mfa_trust
MFA_MAX_VERIFY_ATTEMPTS=5

# OTP
OTP_ENABLED=true
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Cookies
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# CORS
CORS_ORIGIN=https://streamly.zytheran.me
CORS_CREDENTIALS=true
CORS_EXPOSE_HEADERS=Content-Range,Accept-Ranges,Content-Length,Content-Type

# Cloudflare Turnstile
CAPTCHA_PROVIDER=turnstile
CAPTCHA_ENABLED=true
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
CAPTCHA_SMART_MODE=true
CAPTCHA_FAILURE_THRESHOLD=3
CAPTCHA_TRUST_TTL_SECONDS=1800

# Request limits and rate limits
JSON_BODY_LIMIT=16kb
URLENCODED_BODY_LIMIT=16kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
DISABLE_RATE_LIMITING_IN_TEST=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id

# API documentation
API_DOCS_ENABLED=false
API_DOCS_ROUTE=/api/v1/docs
API_DOCS_SPEC_ROUTE=/api/v1/docs/openapi.json

# Email / Twilio SendGrid
EMAIL_ENABLED=true
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@zytheran.me
SENDGRID_FROM_NAME=Streamly

# SMS / Twilio
SMS_ENABLED=true
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=replace-with-twilio-phone-number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_MESSAGING_SERVICE_SID=

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
MOCK_CLOUDINARY=false

# Media storage and video streaming
MEDIA_STORAGE_PROVIDER=s3
VIDEO_STREAMING_ENABLED=true
THUMBNAIL_GENERATION_ENABLED=true
THUMBNAIL_WIDTH=1280
THUMBNAIL_HEIGHT=720
THUMBNAIL_FORMAT=webp

# AWS S3 media
AWS_REGION=ap-south-1
AWS_S3_BUCKET=replace-with-s3-bucket
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_S3_PUBLIC_BASE_URL=https://replace-with-cloudfront-or-s3-url
AWS_S3_FORCE_PATH_STYLE=false

# Jobs
JOBS_ENABLED=true
WORKER_CONCURRENCY=5
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000
EMAIL_QUEUE_ENABLED=true
NOTIFICATION_QUEUE_ENABLED=true
CLEANUP_QUEUE_ENABLED=true
THUMBNAIL_QUEUE_ENABLED=true

# Cache
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_VIDEO_LIST_TTL_SECONDS=60
CACHE_VIDEO_COMMENTS_TTL_SECONDS=30

# RBAC
RBAC_DEFAULT_ROLE=user
RBAC_ADMIN_EMAIL=
