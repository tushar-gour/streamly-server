# =============================================================================
# YouTube Clone Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------

# Port number for the server (default: 8000)
PORT=

# Environment mode: development | production | test
NODE_ENV=

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------

# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
# For local: mongodb://localhost:27017/<database>
MONGODB_URI=

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------

# Allowed origins for CORS (comma-separated for multiple origins)
# Example: http://localhost:3000,http://localhost:5173
CORS_ORIGIN=

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------

# Secret key for access token (use a strong random string)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=

# Access token expiration time
# Format: 1d (1 day), 2h (2 hours), 30m (30 minutes)
ACCESS_TOKEN_EXPIRY=

# Secret key for refresh token (use a different strong random string)
REFRESH_TOKEN_SECRET=

# Refresh token expiration time
REFRESH_TOKEN_EXPIRY=

# -----------------------------------------------------------------------------
# CLOUDINARY CONFIGURATION
# -----------------------------------------------------------------------------

# Cloudinary cloud name (from Cloudinary dashboard)
CLOUDINARY_CLOUD_NAME=

# Cloudinary API key (from Cloudinary dashboard)
CLOUDINARY_API_KEY=

# Cloudinary API secret (from Cloudinary dashboard)
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL CONFIGURATIONS
# -----------------------------------------------------------------------------

# Rate limiting (requests per minute)
# RATE_LIMIT_WINDOW_MS=
# RATE_LIMIT_MAX_REQUESTS=

# File upload limits (in bytes)
# MAX_FILE_SIZE=

# Session configuration
# SESSION_SECRET=
