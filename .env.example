# Streamly Backend Environment

# Server
PORT=8000
NODE_ENV=development
CORS_ORIGIN=*
CORS_CREDENTIALS=true
TRUST_PROXY=false
APP_PUBLIC_BASE_URL=https://streamly.zytheran.me
SERVER_PUBLIC_BASE_URL=https://streamly.zytheran.me
API_DOCS_SERVER_URL=https://streamly.zytheran.me
CORS_EXPOSE_HEADERS=Content-Range,Accept-Ranges,Content-Length,Content-Type
JSON_BODY_LIMIT=16kb
URLENCODED_BODY_LIMIT=16kb
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
DISABLE_RATE_LIMITING_IN_TEST=true
MOCK_CLOUDINARY=true
API_DOCS_ENABLED=true
API_DOCS_ROUTE=/api/v1/docs
API_DOCS_SPEC_ROUTE=/api/v1/docs/openapi.json
LOG_LEVEL=info
LOG_FORMAT=json
REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streamly?schema=public

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

# Jobs
JOBS_ENABLED=true
WORKER_CONCURRENCY=5
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000
EMAIL_QUEUE_ENABLED=true
NOTIFICATION_QUEUE_ENABLED=true
CLEANUP_QUEUE_ENABLED=true
THUMBNAIL_QUEUE_ENABLED=false

# Cache
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_VIDEO_LIST_TTL_SECONDS=60
CACHE_VIDEO_COMMENTS_TTL_SECONDS=30

# JWT
ACCESS_TOKEN_SECRET=replace_with_access_token_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=replace_with_refresh_token_secret
REFRESH_TOKEN_EXPIRY=10d
EMAIL_VERIFICATION_TOKEN_EXPIRY=1d

# MFA / Authenticator app
MFA_ENABLED=false
MFA_ISSUER=Streamly
MFA_SECRET_ENCRYPTION_KEY=
MFA_TRUST_TOKEN_EXPIRY_SECONDS=1800
MFA_CHALLENGE_EXPIRY_SECONDS=300
MFA_DEVICE_COOKIE_NAME=streamly_device_id
MFA_TRUST_COOKIE_NAME=streamly_mfa_trust
MFA_MAX_VERIFY_ATTEMPTS=5

# OTP
OTP_ENABLED=false
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Cloudflare Turnstile captcha
CAPTCHA_PROVIDER=noop
CAPTCHA_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
CAPTCHA_SMART_MODE=true
CAPTCHA_FAILURE_THRESHOLD=3
CAPTCHA_TRUST_TTL_SECONDS=1800

# Email / Twilio SendGrid
EMAIL_ENABLED=false
EMAIL_PROVIDER=noop
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@zytheran.me
SENDGRID_FROM_NAME=Streamly

# SMS / Twilio
SMS_ENABLED=false
SMS_PROVIDER=noop
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_MESSAGING_SERVICE_SID=

# RBAC
RBAC_DEFAULT_ROLE=user
RBAC_ADMIN_EMAIL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret

# Media streaming and storage
MEDIA_STORAGE_PROVIDER=cloudinary
VIDEO_STREAMING_ENABLED=true
THUMBNAIL_GENERATION_ENABLED=false
THUMBNAIL_WIDTH=1280
THUMBNAIL_HEIGHT=720
THUMBNAIL_FORMAT=jpg

# AWS/S3 placeholders for future manual deployment
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_FORCE_PATH_STYLE=false
