{
  "name": "youtube-backend",
  "version": "1.0.0",
  "private": true,
  "description": "A production-grade video platform backend API built with Node.js, TypeScript, Express, PostgreSQL, and Prisma",
  "type": "module",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts tests vitest.config.ts --ext .ts,.mjs",
    "lint:fix": "eslint src scripts tests vitest.config.ts --ext .ts,.mjs --fix",
    "syntax": "node scripts/check-syntax.mjs",
    "smoke": "tsx scripts/smoke.mjs",
    "verify:live": "tsx scripts/verify-live.mjs",
    "verify:docker": "tsx scripts/verify-docker.mjs",
    "verify:jobs": "tsx scripts/verify-jobs.mjs",
    "docs:validate": "tsx scripts/validate-openapi.mjs",
    "jobs:worker": "node dist/src/workers/index.js",
    "jobs:worker:dev": "tsx src/workers/index.ts",
    "seed:rbac": "tsx scripts/seed-rbac.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:ps": "docker compose ps",
    "docker:clean": "docker compose down -v",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm run syntax && npm run smoke",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit tests/services",
    "test:integration": "vitest run tests/integration",
    "test:api": "vitest run tests/api",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.mjs\" \"tests/**/*.ts\" \"docs/**/*.json\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.mjs\" \"tests/**/*.ts\" \"docs/**/*.json\" \"vitest.config.ts\""
  },
  "keywords": [
    "youtube",
    "backend",
    "api",
    "nodejs",
    "express",
    "postgresql",
    "prisma",
    "rest-api"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.79.2",
    "cloudinary": "^2.3.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^10.3.1",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
